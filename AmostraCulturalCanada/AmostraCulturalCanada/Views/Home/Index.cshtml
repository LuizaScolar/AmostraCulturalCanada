@{
    ViewData["Title"] = "Home Page";
}

<style>
    .hero-section {
        /* Opacidade ajustada para a imagem aparecer mais */
        background-image: linear-gradient(rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0.85)), url('https://images.unsplash.com/photo-1503614472-8c93d56e92ce?q=80&w=2000&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        min-height: 95vh; /* Tela inicial mais espaçada */
        display: flex;
        align-items: center;
        padding-top: 50px; /* Evita colar no menu */
    }

    .hero-title-main {
        /* Usando clamp para o texto se adaptar à tela e não cortar */
        font-size: clamp(3.5rem, 8vw, 7rem);
        font-weight: 900;
        line-height: 1.1; /* Ajuste no line-height para não cortar embaixo */
        margin: 0;
        text-transform: uppercase;
        font-family: 'Arial Black', Impact, sans-serif;
    }

    .hero-subtitle {
        color: #222222;
        font-weight: 600;
        max-width: 600px;
        margin-top: 30px;
        font-size: 1.1rem;
        line-height: 1.7;
        border-left: 4px solid #ff0000;
        padding-left: 15px;
    }

    .btn-start {
        background-color: #600000;
        color: white;
        padding: 15px 40px;
        font-weight: bold;
        border: none;
        border-radius: 4px;
        margin-top: 35px;
        text-transform: uppercase;
        letter-spacing: 2px;
        font-size: 0.95rem;
        transition: 0.3s;
        box-shadow: 0 4px 15px rgba(96, 0, 0, 0.4);
    }

        .btn-start:hover {
            background-color: #ff0000;
            transform: translateY(-2px);
        }
</style>

<div class="hero-section">
    <div class="container px-5">
        <div class="row align-items-center">
            <div class="col-md-8">

                <p style="color: #600000; font-weight: bold; letter-spacing: 2px;">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/d/d9/Flag_of_Canada_%28Pantone%29.svg" style="height: 15px; margin-right: 8px;">
                    OFFICIAL TOURISM GUIDE
                </p>

                <h1 class="hero-title-main text-vinho">CONHEÇA O</h1>
                <h1 class="hero-title-main led-red-vivo">CANADÁ</h1>

                <div class="hero-subtitle">
                    Das montanhas rochosas às antigas florestas boreais do norte, a natureza selvagem do Canadá se estende além da imaginação. Descubra lagos glaciais, mitos inuítes e uma cultura raiz impressionante.
                </div>

                <a asp-controller="Home" asp-action="Historia" class="btn-start text-decoration-none d-inline-block">INICIAR JORNADA</a>
            </div>
        </div>
    </div>
</div>