@model AmostraCulturalCanada.Models.Usuario

@{
    ViewData["Title"] = "Acesso";
}

<style>
    /* FUNDO GIGANTE PARA A PÁGINA DE LOGIN */
    .login-page-wrapper {
        background-image: linear-gradient(rgba(10, 10, 10, 0.85), rgba(10, 10, 10, 0.95)), url('https://images.unsplash.com/photo-1473448912268-2022ce9509d8?q=80&w=2000&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        min-height: 85vh; /* Ocupa a tela toda */
        display: flex;
        align-items: center;
        padding: 40px 0;
        margin-top: -16px; /* Cola no menu */
    }

    .auth-container {
        max-width: 900px;
        margin: 0 auto;
        background-color: rgba(17, 17, 17, 0.85); /* Fundo um pouco transparente */
        backdrop-filter: blur(10px); /* Efeito de vidro borrado no fundo */
        border-radius: 8px;
        border: 1px solid #333;
        overflow: hidden;
        box-shadow: 0 15px 40px rgba(0,0,0,0.8);
    }

    .auth-box {
        padding: 40px;
    }

    .auth-border-right {
        border-right: 1px solid #333;
    }

    .auth-title {
        color: #ff0000;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 25px;
    }

    .form-control-custom {
        background-color: rgba(26, 26, 26, 0.8) !important;
        border: 1px solid #444 !important;
        color: white !important;
        padding: 12px !important;
        border-radius: 4px !important;
    }

        .form-control-custom:focus {
            border-color: #ff0000 !important;
            box-shadow: none !important;
        }

    .btn-auth {
        background-color: #ff0000;
        color: white;
        font-weight: bold;
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 4px;
        text-transform: uppercase;
        margin-top: 15px;
        transition: 0.3s;
    }

        .btn-auth:hover {
            background-color: #cc0000;
        }

    .error-text {
        color: #ff4d4d;
        font-size: 0.85rem;
    }
</style>

<div class="login-page-wrapper">
    <div class="container">
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert alert-success bg-dark text-success border-success text-center mb-4">
                @TempData["Sucesso"]
            </div>
        }

        <div class="auth-container row g-0">
            <div class="col-md-6 auth-box auth-border-right">
                <h2 class="auth-title led-red">Entrar</h2>

                @if (ViewBag.Erro != null)
                {
                    <div class="alert alert-danger bg-dark text-danger border-danger p-2 small">@ViewBag.Erro</div>
                }

                <form asp-action="Logar" method="post">
                    <div class="mb-3">
                        <label class="form-label text-secondary small">E-mail</label>
                        <input type="email" name="email" class="form-control form-control-custom" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small">Senha</label>
                        <input type="password" name="senha" class="form-control form-control-custom" required />
                    </div>
                    <button type="submit" class="btn-auth">Acessar o Quiz</button>
                </form>
            </div>

            <div class="col-md-6 auth-box">
                <h2 class="auth-title led-red">Criar Conta</h2>

                <form asp-action="Registrar" method="post">
                    <div class="mb-3">
                        <label class="form-label text-secondary small">Nome Completo</label>
                        <input asp-for="Nome" type="text" class="form-control form-control-custom" />
                        <span asp-validation-for="Nome" class="error-text"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small">E-mail Válido</label>
                        <input asp-for="Email" type="email" class="form-control form-control-custom" />
                        <span asp-validation-for="Email" class="error-text"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small">Escolha uma Senha</label>
                        <input asp-for="Senha" type="password" class="form-control form-control-custom" />
                        <span asp-validation-for="Senha" class="error-text"></span>
                    </div>
                    <button type="submit" class="btn-auth" style="background-color: rgba(34,34,34,0.8); border: 1px solid #ff0000;">Cadastrar</button>
                </form>
            </div>
        </div>
    </div>
</div>