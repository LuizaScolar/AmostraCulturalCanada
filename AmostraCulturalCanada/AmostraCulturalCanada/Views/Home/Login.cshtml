@model AmostraCulturalCanada.Models.Usuario

@{
    ViewData["Title"] = "Acesso";
}

<style>
    .login-page-wrapper {
        background-image: linear-gradient(rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0.8)), url('https://images.unsplash.com/photo-1473448912268-2022ce9509d8?q=80&w=2000&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        min-height: 90vh;
        display: flex;
        align-items: center;
        padding: 40px 0;
    }

    .auth-container {
        max-width: 900px;
        margin: 0 auto;
        background-color: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(8px);
        border-radius: 8px;
        border: 1px solid #d0d0d0;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    }

    .auth-box {
        padding: 40px;
    }

    .auth-border-right {
        border-right: 1px solid #d0d0d0;
    }

    .auth-title {
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 25px;
    }

    .form-control-custom {
        background-color: rgba(255, 255, 255, 0.95) !important;
        border: 1px solid #cccccc !important;
        color: #333333 !important;
        padding: 12px !important;
        border-radius: 4px !important;
    }

        .form-control-custom:focus {
            border-color: #ff0000 !important;
            box-shadow: 0 0 5px rgba(255,0,0,0.2) !important;
        }

    .btn-auth {
        background-color: #600000;
        color: white;
        font-weight: bold;
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 4px;
        text-transform: uppercase;
        margin-top: 15px;
        transition: 0.3s;
    }

        .btn-auth:hover {
            background-color: #ff0000;
            box-shadow: 0 4px 12px rgba(255,0,0,0.3);
        }

    .error-text {
        color: #cc0000;
        font-size: 0.85rem;
    }
</style>

<div class="login-page-wrapper">
    <div class="container">
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert alert-success bg-white text-success border-success text-center mb-4 shadow-sm">
                @TempData["Sucesso"]
            </div>
        }

        <div class="auth-container row g-0">
            <div class="col-md-6 auth-box auth-border-right">
                <h2 class="auth-title text-vinho">Entrar</h2>

                @if (ViewBag.Erro != null)
                {
                    <div class="alert alert-danger bg-white text-danger border-danger p-2 small shadow-sm">@ViewBag.Erro</div>
                }

                <form asp-action="Logar" method="post">
                    <div class="mb-3">
                        <label class="form-label text-muted small" style="font-weight:600;">E-mail</label>
                        <input type="email" name="email" class="form-control form-control-custom" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small" style="font-weight:600;">Senha</label>
                        <input type="password" name="senha" class="form-control form-control-custom" required />
                    </div>
                    <button type="submit" class="btn-auth">Acessar o Quiz</button>
                </form>
            </div>

            <div class="col-md-6 auth-box">
                <h2 class="auth-title led-red-vivo">Criar Conta</h2>

                <form asp-action="Registrar" method="post">
                    <div class="mb-3">
                        <label class="form-label text-muted small" style="font-weight:600;">Nome Completo</label>
                        <input asp-for="Nome" type="text" class="form-control form-control-custom" />
                        <span asp-validation-for="Nome" class="error-text"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small" style="font-weight:600;">E-mail Válido</label>
                        <input asp-for="Email" type="email" class="form-control form-control-custom" />
                        <span asp-validation-for="Email" class="error-text"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small" style="font-weight:600;">Escolha uma Senha</label>
                        <input asp-for="Senha" type="password" class="form-control form-control-custom" />
                        <span asp-validation-for="Senha" class="error-text"></span>
                    </div>
                    <button type="submit" class="btn-auth" style="background-color: #ffffff; border: 2px solid #600000; color: #600000;">Cadastrar</button>
                </form>
            </div>
        </div>
    </div>
</div>