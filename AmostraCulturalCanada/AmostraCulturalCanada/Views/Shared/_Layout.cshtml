<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Visit Canada</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AmostraCulturalCanada.styles.css" asp-append-version="true" />

    <style>
            body {
                background-color: #0a0a0a; /* Fundo super escuro */
                color: #ffffff; /* Letras brancas */
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }

            /* Estilo da Barra de Navegação */
            .navbar {
                background-color: #0a0a0a !important;
                border-bottom: 1px solid #333;
                padding: 15px 0;
            }
            .navbar-brand {
                color: #ff0000 !important; /* Vermelho do tema */
                font-weight: 800;
                letter-spacing: 2px;
                font-size: 1.2rem;
            }
            .nav-link {
                color: #aaaaaa !important;
                text-transform: uppercase;
                font-size: 0.85rem;
                font-weight: 700;
                letter-spacing: 1px;
                margin: 0 15px;
                transition: color 0.3s ease;
            }
            .nav-link:hover {
                color: #ff0000 !important; /* Fica vermelho ao passar o mouse */
            }

            /* Estilo do Rodapé */
            .footer {
                background-color: #0a0a0a;
                border-top: 1px solid #333 !important;
                color: #aaaaaa;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark">
            <div class="container-fluid px-5">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">TRAVEL & DESTINATIONS</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 justify-content-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Historia">HISTÓRIA</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Cultura">CULTURA</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Folclore">FOLCLORE</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Quiz">QUIZ</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav">
                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-5 py-4">
        <div class="container d-flex justify-content-between align-items-center">
            <div>
                <h5 style="color: white; font-weight: bold;">VISIT <span style="color: red;">CANADA</span></h5>
                <small>© 2026 Visit Canada Initiative - Cultura e Folclore</small>
            </div>
            <div>
                <small>Ottawa, ON - Canada</small>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>